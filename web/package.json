{
  "name": "@ranjeet_/digital-pet",
  "version": "0.2.0",
  "description": "A customizable digital pet web component. The default pet is Shiro, a playful golden retriever.",
  "homepage": "https://ranjeet447.github.io/digital-pet/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ranjeet447/digital-pet.git",
    "directory": "web"
  },
  "bugs": {
    "url": "https://github.com/ranjeet447/digital-pet/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly && esbuild src/index.ts --bundle --format=esm --target=es2020 --outfile=dist/index.js --sourcemap",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "digital-pet",
    "web-component",
    "golden-retriever",
    "webgl",
    "threejs",
    "website-widget",
    "shiro"
  ],
  "license": "MIT",
  "sideEffects": true,
  "devDependencies": {
    "@types/three": "^0.184.1",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "three": "^0.184.0"
  }
}
